# --- General ---
NODE_ENV=development
LOG_LEVEL=info

# --- Auth Service ---
AUTH_SERVICE_PORT=4001
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRY=15m

# --- OTP Fallback Channels ---
OTP_TIMEOUT_MS=1800
SMS_GATEWAY_API_KEY=your-sms-gateway-key
SMS_GATEWAY_URL=https://your-sms-provider.example.com
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-id
VOICE_IVR_PROVIDER_KEY=your-ivr-provider-key

# --- Claims Ingestion ---
CLAIMS_SERVICE_PORT=4002
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nyaticare-claims
KAFKA_CLAIMS_TOPIC=sha.claims.ingestion
OFFLINE_QUEUE_DB_PATH=./data/offline-queue.sqlite

# --- Patient Registry ---
PATIENT_REGISTRY_PORT=4003
REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=3600

# --- Database ---
DATABASE_URL=postgresql://nyaticare:nyaticare@postgres:5432/nyaticare_gateway

# --- Downstream: Taifa Care Central HMIS (mock in dev) ---
TAIFA_CARE_BASE_URL=https://sandbox.taifacare.example.go.ke
TAIFA_CARE_CLIENT_ID=your-client-id
TAIFA_CARE_CLIENT_SECRET=your-client-secret

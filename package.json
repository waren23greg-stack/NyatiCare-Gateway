{
  "name": "nyaticare-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Resilient distributed intermediary for Taifa Care HMIS & SHA integration",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "eslint": "^10.6.0"
  }
}
